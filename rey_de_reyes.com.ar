<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Rey de Reyes Construcciones | Mendoza</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
  <style>
    :root{
      --gold:#B8922A;--gold2:#D4A82A;--gold3:#F0C94A;--gold-pale:#FDF6E3;
      --dark:#1A1A1A;--dark2:#2D2D2D;--mid:#6B6B6B;
      --light:#F7F7F7;--white:#FFFFFF;--border:#E8E0D0;
      --elec:#1565C0;--elec-bg:#EBF2FF;
      --paint:#880E4F;--paint-bg:#FCE4EC;
      --durl:#4E342E;--durl-bg:#EFEBE9;
      --gas:#1B5E20;--gas-bg:#E8F5E9;
    }
    *{margin:0;padding:0;box-sizing:border-box;}
    html{scroll-behavior:smooth;}
    body{background:var(--white);color:var(--dark);font-family:'Montserrat',sans-serif;overflow-x:hidden;}

    /* NAV */
    nav{position:sticky;top:0;z-index:100;background:var(--white);border-bottom:1px solid var(--border);box-shadow:0 2px 12px rgba(0,0,0,.06);}
    .nav-inner{max-width:1140px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:70px;padding:0 28px;}
    .nav-logo{height:46px;border-radius:6px;}
    .nav-links{display:flex;gap:28px;list-style:none;align-items:center;}
    .nav-links a{color:var(--mid);text-decoration:none;font-size:0.76rem;letter-spacing:0.1em;text-transform:uppercase;font-weight:600;transition:color .2s;}
    .nav-links a:hover{color:var(--gold);}
    .nav-cta{background:var(--gold)!important;color:var(--white)!important;padding:9px 18px;border-radius:4px;transition:background .2s!important;}
    .nav-cta:hover{background:var(--dark)!important;}
    @media(max-width:768px){.nav-links{display:none;}}

    /* HERO */
    .hero{background:linear-gradient(135deg,#1A1A1A 0%,#2D2D2D 40%,#3D3010 70%,#1A1A1A 100%);min-height:92vh;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden;text-align:center;padding:60px 24px;}
    .hero-texture{position:absolute;inset:0;background-image:radial-gradient(circle at 20% 50%,rgba(184,146,42,.12) 0%,transparent 50%),radial-gradient(circle at 80% 20%,rgba(184,146,42,.08) 0%,transparent 40%);}
    .hero-grid{position:absolute;inset:0;background-image:linear-gradient(rgba(184,146,42,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(184,146,42,.04) 1px,transparent 1px);background-size:60px 60px;}
    .hero-content{position:relative;z-index:2;max-width:780px;}
    .hero-logo{width:min(360px,80vw);border-radius:14px;filter:drop-shadow(0 8px 40px rgba(184,146,42,.35));animation:fadeDown .9s ease forwards;margin-bottom:28px;}
    .hero-badge{display:inline-block;background:rgba(184,146,42,.15);border:1px solid rgba(184,146,42,.4);color:var(--gold3);font-size:0.68rem;letter-spacing:.2em;text-transform:uppercase;padding:6px 18px;border-radius:20px;font-weight:600;margin-bottom:20px;animation:fadeUp .9s .2s ease both;}
    .hero-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,5vw,3.2rem);color:var(--white);line-height:1.15;animation:fadeUp .9s .35s ease both;margin-bottom:16px;}
    .hero-title span{color:var(--gold3);}
    .hero-sub{color:rgba(255,255,255,.6);font-size:clamp(.83rem,2vw,.97rem);letter-spacing:.04em;line-height:1.7;animation:fadeUp .9s .5s ease both;margin-bottom:36px;}
    .hero-btns{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;animation:fadeUp .9s .65s ease both;}
    .btn-primary{background:var(--gold2);color:var(--dark);font-weight:700;font-size:.8rem;letter-spacing:.12em;text-transform:uppercase;padding:14px 30px;border-radius:4px;text-decoration:none;display:inline-flex;align-items:center;gap:10px;transition:all .3s;box-shadow:0 4px 20px rgba(184,146,42,.4);}
    .btn-primary:hover{background:var(--gold3);transform:translateY(-2px);}
    .btn-secondary{background:transparent;color:var(--white);font-weight:600;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;padding:13px 26px;border-radius:4px;text-decoration:none;border:1.5px solid rgba(255,255,255,.35);display:inline-flex;align-items:center;gap:10px;transition:all .3s;}
    .btn-secondary:hover{border-color:var(--gold3);color:var(--gold3);transform:translateY(-2px);}

    /* STATS */
    .stats-bar{background:var(--dark);padding:22px 28px;}
    .stats-inner{max-width:1140px;margin:0 auto;display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:0;}
    .stat-item{display:flex;align-items:center;gap:12px;padding:8px 36px;border-right:1px solid rgba(255,255,255,.1);}
    .stat-item:last-child{border-right:none;}
    .stat-num{font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--gold3);font-weight:700;}
    .stat-label{font-size:.7rem;color:rgba(255,255,255,.5);letter-spacing:.08em;line-height:1.4;}
    @media(max-width:600px){.stat-item{padding:8px 20px;border-right:none;border-bottom:1px solid rgba(255,255,255,.1);width:100%;justify-content:center;}.stat-item:last-child{border-bottom:none;}}

    /* SECTIONS */
    .section-wrapper{max-width:1140px;margin:0 auto;padding:80px 28px;}
    .section-eyebrow{font-size:.68rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);font-weight:700;margin-bottom:12px;display:flex;align-items:center;gap:12px;}
    .section-eyebrow::after{content:'';flex:1;height:1px;background:var(--border);max-width:60px;}
    .section-title{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,3.5vw,2.4rem);color:var(--dark);line-height:1.2;margin-bottom:14px;}
    .section-title span{color:var(--gold);}
    .section-desc{color:var(--mid);font-size:.95rem;line-height:1.75;max-width:580px;}
    .divider-line{width:48px;height:3px;background:linear-gradient(90deg,var(--gold),var(--gold3));border-radius:2px;margin:20px 0;}

    /* SERVICE CARDS */
    #servicios{background:var(--light);}
    .services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(272px,1fr));gap:22px;margin-top:48px;}
    .service-card{background:var(--white);border-radius:12px;border:1px solid var(--border);overflow:hidden;transition:transform .3s,box-shadow .3s;box-shadow:0 2px 12px rgba(0,0,0,.05);}
    .service-card:hover{transform:translateY(-6px);box-shadow:0 16px 48px rgba(0,0,0,.12);}
    .card-img{width:100%;height:196px;object-fit:cover;display:block;}
    .card-img-label{padding:7px 16px;font-size:.66rem;letter-spacing:.1em;font-weight:600;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:6px;}
    .card-top{padding:18px 18px 14px;border-bottom:1px solid var(--border);}
    .card-service-tag{display:inline-flex;align-items:center;gap:6px;font-size:.63rem;font-weight:700;letter-spacing:.15em;text-transform:uppercase;padding:3px 10px;border-radius:3px;margin-bottom:10px;}
    .card-heading{font-family:'Playfair Display',serif;font-size:1.25rem;color:var(--dark);margin-bottom:3px;}
    .card-subhead{font-size:.73rem;color:var(--mid);}
    .card-body{padding:16px 18px 18px;}
    .card-desc{font-size:.84rem;color:var(--mid);line-height:1.62;margin-bottom:14px;}
    .svc-list{list-style:none;display:flex;flex-direction:column;gap:6px;margin-bottom:16px;}
    .svc-list li{display:flex;align-items:flex-start;gap:8px;font-size:.81rem;color:var(--dark2);padding-bottom:6px;border-bottom:1px solid var(--light);}
    .svc-list li:last-child{border-bottom:none;padding-bottom:0;}
    .chk{width:16px;height:16px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.52rem;font-weight:700;flex-shrink:0;margin-top:1px;}
    .card-btn{display:block;text-align:center;padding:10px;border-radius:6px;font-size:.73rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;transition:all .2s;}
    /* colors */
    .elec-tag{background:var(--elec-bg);color:var(--elec);} .elec-label{color:var(--elec);} .elec-chk{background:var(--elec-bg);color:var(--elec);} .elec-btn{background:var(--elec-bg);color:var(--elec);border:1px solid rgba(21,101,192,.25);} .elec-btn:hover{background:var(--elec);color:var(--white);}
    .paint-tag{background:var(--paint-bg);color:var(--paint);} .paint-label{color:var(--paint);} .paint-chk{background:var(--paint-bg);color:var(--paint);} .paint-btn{background:var(--paint-bg);color:var(--paint);border:1px solid rgba(136,14,79,.25);} .paint-btn:hover{background:var(--paint);color:var(--white);}
    .durl-tag{background:var(--durl-bg);color:var(--durl);} .durl-label{color:var(--durl);} .durl-chk{background:var(--durl-bg);color:var(--durl);} .durl-btn{background:var(--durl-bg);color:var(--durl);border:1px solid rgba(78,52,46,.25);} .durl-btn:hover{background:var(--durl);color:var(--white);}
    .gas-tag{background:var(--gas-bg);color:var(--gas);} .gas-label{color:var(--gas);} .gas-chk{background:var(--gas-bg);color:var(--gas);} .gas-btn{background:var(--gas-bg);color:var(--gas);border:1px solid rgba(27,94,32,.25);} .gas-btn:hover{background:var(--gas);color:var(--white);}

    /* GALLERY */
    #galeria{background:var(--white);}
    .gallery-header{display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:16px;}
    .gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:36px;}
    @media(max-width:680px){.gallery-grid{grid-template-columns:repeat(2,1fr);}}
    .gallery-item{position:relative;border-radius:8px;overflow:hidden;aspect-ratio:4/3;cursor:pointer;box-shadow:0 2px 10px rgba(0,0,0,.08);}
    .gallery-item img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s;}
    .gallery-item:hover img{transform:scale(1.07);}
    .g-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(26,26,26,.75) 0%,transparent 55%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:12px;}
    .gallery-item:hover .g-overlay{opacity:1;}
    .g-text{font-size:.66rem;font-weight:700;color:var(--gold3);letter-spacing:.1em;text-transform:uppercase;}
    .lb{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.92);align-items:center;justify-content:center;}
    .lb.open{display:flex;}
    .lb img{max-width:92vw;max-height:88vh;border-radius:8px;}
    .lb-close{position:absolute;top:20px;right:28px;color:var(--white);font-size:2.2rem;cursor:pointer;}

    /* BENEFITS */
    #beneficios{background:var(--dark);}
    .benefits-inner{max-width:1140px;margin:0 auto;padding:80px 28px;}
    .benefits-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(185px,1fr));gap:18px;margin-top:44px;}
    .benefit-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:10px;padding:26px 18px;text-align:center;transition:border-color .3s,transform .3s;}
    .benefit-card:hover{border-color:rgba(212,168,42,.4);transform:translateY(-4px);}
    .benefit-icon{font-size:1.9rem;margin-bottom:12px;}
    .benefit-title{font-family:'Playfair Display',serif;font-size:.92rem;color:var(--gold3);margin-bottom:7px;}
    .benefit-text{font-size:.78rem;color:rgba(255,255,255,.5);line-height:1.62;}
    .section-title-white{font-family:'Playfair Display',serif;font-size:clamp(1.5rem,3vw,2.2rem);color:var(--white);line-height:1.2;margin-bottom:14px;}
    .section-title-white span{color:var(--gold3);}
    .section-eyebrow-white{font-size:.66rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold2);font-weight:700;margin-bottom:12px;}
    .divider-gold{width:48px;height:3px;background:linear-gradient(90deg,var(--gold),var(--gold3));border-radius:2px;margin:20px 0;}

    /* CONTACT */
    #contacto{background:var(--light);border-top:1px solid var(--border);}
    .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:start;margin-top:44px;}
    @media(max-width:720px){.contact-grid{grid-template-columns:1fr;}}
    .contact-box{background:var(--white);border:1px solid var(--border);border-radius:12px;padding:28px;box-shadow:0 4px 20px rgba(0,0,0,.06);}
    .contact-box h3{font-family:'Playfair Display',serif;font-size:1.15rem;color:var(--dark);margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid var(--border);}
    .contact-line{display:flex;align-items:center;gap:12px;margin-bottom:14px;}
    .c-icon{width:38px;height:38px;border-radius:8px;background:var(--gold-pale);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.95rem;flex-shrink:0;}
    .c-label{font-size:.68rem;text-transform:uppercase;letter-spacing:.1em;color:var(--mid);margin-bottom:1px;font-weight:600;}
    .c-value{font-size:.9rem;color:var(--dark);font-weight:600;}
    .wa-btn{background:linear-gradient(135deg,#128C7E,#25D366);color:var(--white);font-weight:700;font-size:.92rem;letter-spacing:.06em;padding:17px 22px;border:none;border-radius:8px;cursor:pointer;text-decoration:none;display:flex;align-items:center;justify-content:center;gap:12px;transition:all .3s;box-shadow:0 4px 20px rgba(37,211,102,.3);width:100%;margin-bottom:10px;}
    .wa-btn:hover{transform:translateY(-3px);box-shadow:0 10px 30px rgba(37,211,102,.45);}
    .wa-note{text-align:center;font-size:.71rem;color:var(--mid);}
    .services-chips{display:flex;flex-wrap:wrap;gap:7px;margin-top:22px;padding-top:18px;border-top:1px solid var(--border);}
    .chip{background:var(--light);border:1px solid var(--border);border-radius:20px;padding:4px 12px;font-size:.68rem;font-weight:600;color:var(--mid);}

    /* FLOAT */
    .float-wa{position:fixed;bottom:28px;right:28px;z-index:999;background:#25D366;width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;text-decoration:none;box-shadow:0 4px 20px rgba(37,211,102,.5);animation:pulse 2.5s infinite;}
    .float-wa:hover{transform:scale(1.1);}
    @keyframes pulse{0%,100%{box-shadow:0 4px 20px rgba(37,211,102,.5);}50%{box-shadow:0 4px 32px rgba(37,211,102,.8),0 0 0 8px rgba(37,211,102,.15);}}

    /* FOOTER */
    footer{background:var(--dark);padding:36px 28px;text-align:center;border-top:3px solid var(--gold);}
    .footer-logo{height:52px;border-radius:8px;margin-bottom:12px;}
    .footer-name{font-family:'Playfair Display',serif;color:var(--gold3);font-size:.95rem;margin-bottom:5px;}
    .footer-sub{color:rgba(255,255,255,.4);font-size:.73rem;letter-spacing:.08em;}
    .footer-faith{color:var(--gold);font-size:.7rem;margin-top:14px;letter-spacing:.15em;font-weight:600;}

    /* ANIM */
    @keyframes fadeDown{from{opacity:0;transform:translateY(-24px);}to{opacity:1;transform:translateY(0);}}
    @keyframes fadeUp{from{opacity:0;transform:translateY(24px);}to{opacity:1;transform:translateY(0);}}
    .fi{opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease;}
    .fi.v{opacity:1;transform:none;}
  </style>
</head>
<body>

<div class="lb" id="lb" onclick="this.classList.remove('open')">
  <span class="lb-close">&times;</span>
  <img id="lb-img" src="" alt=""/>
</div>
<a href="https://wa.me/5492616841352" target="_blank" class="float-wa">
  <svg width="28" height="28" viewBox="0 0 32 32" fill="white"><path d="M16 2C8.28 2 2 8.28 2 16c0 2.41.64 4.67 1.76 6.63L2 30l7.58-1.72A13.93 13.93 0 0016 30c7.72 0 14-6.28 14-14S23.72 2 16 2zm7.08 19.56c-.3.84-1.74 1.6-2.42 1.66-.62.06-1.2.28-4.06-.84-3.42-1.36-5.6-4.88-5.78-5.12-.16-.24-1.36-1.8-1.36-3.44 0-1.64.86-2.44 1.16-2.78.3-.34.66-.42.88-.42h.64c.2 0 .48-.08.74.56l.98 2.54c.06.16.02.34-.06.5l-.5.76c-.1.14-.2.3-.08.56.5 1 1.36 2.04 2.56 2.86 1.02.68 2.08 1 2.54 1.08.34.06.5-.04.68-.24l.52-.62c.16-.2.34-.24.54-.16l1.8.84c.62.28.62.28.62.56z"/></svg>
</a>

<!-- NAV -->
<nav>
  <div class="nav-inner">
    <a href="#"><img src="data:image/jpeg;base64," alt="Rey de Reyes" class="nav-logo"/></a>
    <ul class="nav-links">
      <li><a href="#servicios">Servicios</a></li>
      <li><a href="#galeria">Trabajos</a></li>
      <li><a href="#beneficios">Nosotros</a></li>
      <li><a href="https://wa.me/5492616841352" target="_blank" class="nav-cta">Presupuesto</a></li>
    </ul>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-texture"></div>
  <div class="hero-grid"></div>
  <div class="hero-content">
    <img src="data:image/jpeg;base64," alt="Rey de Reyes" class="hero-logo"/>
    <span class="hero-badge">✝ Mendoza · Argentina</span>
    <h1 class="hero-title">Construimos tu espacio<br/>con <span>fe y excelencia</span></h1>
    <p class="hero-sub">Electricidad · Pintura · Durlock / Steel Frame · Gas<br/>Soluciones integrales para tu hogar y empresa en Mendoza</p>
    <div class="hero-btns">
      <a href="#servicios" class="btn-primary">Ver todos los servicios</a>
      <a href="https://wa.me/5492616841352?text=Hola!%20Quiero%20un%20presupuesto%20de%20Rey%20de%20Reyes%20Construcciones" target="_blank" class="btn-secondary">Pedir Presupuesto</a>
    </div>
  </div>
</section>

<!-- STATS -->
<div class="stats-bar">
  <div class="stats-inner">
    <div class="stat-item"><div class="stat-num">+10</div><div class="stat-label">Años de<br/>experiencia</div></div>
    <div class="stat-item"><div class="stat-num">5</div><div class="stat-label">Servicios<br/>especializados</div></div>
    <div class="stat-item"><div class="stat-num">100%</div><div class="stat-label">Trabajos<br/>garantizados</div></div>

  </div>
</div>

<!-- SERVICIOS -->
<section id="servicios">
  <div class="section-wrapper">
    <div class="fi">
      <p class="section-eyebrow">Nuestros servicios</p>
      <h2 class="section-title">Todo lo que necesitás <span>para tu obra</span></h2>
      <div class="divider-line"></div>
      <p class="section-desc">Profesionales especializados en cada rubro. Materiales de primera calidad, presupuesto detallado y garantía en todos los trabajos.</p>
    </div>
    <div class="services-grid">

      <!-- ELECTRICISTA -->
      <div class="service-card fi">
        <img class="card-img" src="data:image/png;base64," alt="Electricista profesional"/>
        <p class="card-img-label elec-label">⚡ Especialista en instalaciones eléctricas</p>
        <div class="card-top">
          <span class="card-service-tag elec-tag">⚡ Electricidad</span>
          <h3 class="card-heading">Electricista</h3>
          <p class="card-subhead">Instalaciones certificadas y habilitadas</p>
        </div>
        <div class="card-body">
          <p class="card-desc">Instalaciones seguras y modernas. Desde una toma hasta el tendido completo de un edificio o comercio.</p>
          <ul class="svc-list">
            <li><span class="chk elec-chk">✓</span><span><b>Instalación eléctrica completa</b> — casas, deptos y comercios</span></li>
            <li><span class="chk elec-chk">✓</span><span><b>Tableros eléctricos</b> — nueva instalación y renovación</span></li>
            <li><span class="chk elec-chk">✓</span><span><b>Iluminación LED</b> — interior, exterior y jardines</span></li>
            <li><span class="chk elec-chk">✓</span><span><b>Aires acondicionados</b> — instalación y mantenimiento</span></li>
            <li><span class="chk elec-chk">✓</span><span><b>Porteros eléctricos</b> e intercomunicadores</span></li>
            <li><span class="chk elec-chk">✓</span><span><b>Certificados eléctricos</b> para habilitación municipal</span></li>
            <li><span class="chk elec-chk">✓</span><span><b>Urgencias</b> — cortocircuitos y fallas eléctricas</span></li>
          </ul>
          <a href="https://wa.me/5492616841352?text=Hola!%20Necesito%20un%20electricista" target="_blank" class="card-btn elec-btn">Consultar Electricista →</a>
        </div>
      </div>

      <!-- PINTOR -->
      <div class="service-card fi">
        <img class="card-img" src="data:image/png;base64," alt="Pintor profesional"/>
        <p class="card-img-label paint-label">🎨 Acabados de pintura con protección total</p>
        <div class="card-top">
          <span class="card-service-tag paint-tag">🎨 Pintura</span>
          <h3 class="card-heading">Pintor</h3>
          <p class="card-subhead">Acabados premium en interiores y exteriores</p>
        </div>
        <div class="card-body">
          <p class="card-desc">Transformamos cualquier espacio con técnicas profesionales. Pinturas de primera, texturas y acabados decorativos únicos.</p>
          <ul class="svc-list">
            <li><span class="chk paint-chk">✓</span><span><b>Pintura interior</b> — látex, esmalte, temple y microcemento</span></li>
            <li><span class="chk paint-chk">✓</span><span><b>Pintura exterior</b> — fachadas, medianeras y fondos</span></li>
