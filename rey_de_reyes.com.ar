<script>
  const els=document.querySelectorAll('.fi');
  const io=new IntersectionObserver((e)=>{e.forEach((x,i)=>{if(x.isIntersecting){setTimeout(()=>x.target.classList.add('v'),i*60);io.unobserve(x.target);}});},{threshold:0.08});
  els.forEach(el=>io.observe(el));
  function openLb(el){document.getElementById('lb-img').src=el.querySelector('img').src;document.getElementById('lb').classList.add('open');}
</script>
